// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("CLIENT") // CLIENT, EXTRA, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  missions  Mission[]
}

model Extra {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  birthDate   DateTime?
  skills      String   // Comma separated or JSON
  experience  String?
  bio         String?
  cvUrl       String?
  avatarUrl   String?
  password    String?  // Hashé en production
  rating      Float    @default(0)
  status      String   @default("VERIFICATION") // ACTIF, VERIFICATION
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  applications Application[]
  results     TestResult[]
}

model Mission {
  id          String   @id @default(cuid())
  company     String
  type        String   // Equiv to title/role
  location    String
  date        DateTime
  amount      Float
  status      String   @default("EN_ATTENTE") // EN_ATTENTE, CONFIRME, TERMINE
  clientId    String?
  client      User?    @relation(fields: [clientId], references: [id])
  applications Application[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id        String   @id @default(cuid())
  missionId String
  extraId   String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id])
  extra     Extra    @relation(fields: [extraId], references: [id])
}
model SkillTest {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   // Hospitality category
  questions   String   // JSON string of questions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  results     TestResult[]
}

model TestResult {
  id        String   @id @default(cuid())
  extraId   String
  testId    String
  score     Int
  passed    Boolean
  createdAt DateTime @default(now())
  extra     Extra    @relation(fields: [extraId], references: [id])
  test      SkillTest @relation(fields: [testId], references: [id])
}
