// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  companyName        String?
  password           String?
  role               String    @default("CLIENT") // CLIENT, EXTRA, ADMIN
  stripeCustomerId   String?   // Added for Stripe Checkout
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  missions           Mission[]
  conversations      Conversation[]
}

model Extra {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  birthDate   DateTime?
  skills      String   // Comma separated or JSON
  experience  String?
  bio         String?
  cvUrl       String?
  avatarUrl   String?
  password    String?  // Hashé en production
  rating      Float    @default(0)
  status          String   @default("VERIFICATION") // ACTIF, VERIFICATION
  stripeAccountId String?  // Added for Stripe Connect (Payouts)
  createdAt       DateTime @default(now())
  updatedAt   DateTime @updatedAt
  applications Application[]
  results         TestResult[]
  conversations   Conversation[]
}

model Mission {
  id          String   @id @default(cuid())
  company     String
  type        String   // Equiv to title/role
  location    String
  date        DateTime
  amount      Float
  status      String   @default("EN_ATTENTE") // EN_ATTENTE, CONFIRME, TERMINE
  clientId    String?
  client      User?    @relation(fields: [clientId], references: [id])
  applications Application[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime  @updatedAt
  payment     Payment?
  conversations Conversation[]
}

model Application {
  id        String   @id @default(cuid())
  missionId String
  extraId   String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id])
  extra     Extra    @relation(fields: [extraId], references: [id])
}
model SkillTest {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   // Hospitality category
  questions   String   // JSON string of questions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  results     TestResult[]
}

model TestResult {
  id        String   @id @default(cuid())
  extraId   String
  testId    String
  score     Int
  passed    Boolean
  createdAt DateTime @default(now())
  extra     Extra    @relation(fields: [extraId], references: [id])
  test      SkillTest @relation(fields: [testId], references: [id])
}

model SiteSettings {
  id                  String  @id @default("global")
  commission          Float   @default(15)
  registrationsOpen   Boolean @default(true)
  autoApprove         Boolean @default(false)
  emailNotifications  Boolean @default(true)
  adminEmail          String  @default("admin@extranow.fr")
  updatedAt           DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  missionId     String   @unique
  amount        Float
  stripeSession String?
  status        String   @default("PENDING") // PENDING, PAID, REFUNDED
  createdAt     DateTime @default(now())
  mission       Mission  @relation(fields: [missionId], references: [id])
}

model Conversation {
  id          String    @id @default(cuid())
  missionId   String?
  clientId    String
  extraId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  client      User      @relation(fields: [clientId], references: [id])
  extra       Extra     @relation(fields: [extraId], references: [id])
  mission     Mission?  @relation(fields: [missionId], references: [id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String       // Peut être l'ID du client ou de l'extra
  text           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
